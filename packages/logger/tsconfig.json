{
  "compilerOptions": {
    "strict": true,
    "outDir": "build",
    "target": "ES2020",
    "declaration": true,
    "module": "nodenext",
    "skipLibCheck": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "moduleResolution": "NodeNext",
    "forceConsistentCasingInFileNames": true,
  },
  "include": ["src"],
  "exclude": ["test"]
}
